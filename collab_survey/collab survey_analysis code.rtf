# Helper function: descriptives (Mean, SD, Min, Max, N)\
desc_stats <- function(data, var) \{\
  x <- data[[var]]\
  x <- x[!is.na(x)]\
  data.frame(\
    Variable = var,\
    N = length(x),\
    Mean = round(mean(x), 2),\
    SD = round(sd(x), 2),\
    Min = min(x),\
    Max = max(x)\
  )\
\}\
\
# Helper: frequency table with percentages\
freq_with_pct <- function(data, var) \{\
  x <- data[[var]]\
  tbl <- table(x, useNA = "ifany")\
  pct <- round(prop.table(tbl) * 100, 1)\
  result <- data.frame(\
    Value = names(tbl),\
    N = as.integer(tbl),\
    Pct = as.numeric(pct)\
  )\
  cat("\\n---", var, "---\\n")\
  print(result, row.names = FALSE)\
  invisible(result)\
\}\
