  "Dignity-Self"  = list(items = 5:10,  correct = 1),\
  "Dignity-Other" = list(items = 11:16, correct = 2),\
  "Honor-Self"    = list(items = 17:22, correct = 3),\
  "Honor-Other"   = list(items = 23:29, correct = 4),\
  "Face-Self"     = list(items = 30:35, correct = 5),\
  "Face-Other"    = list(items = 36:40, correct = 6)\
)\
\
cat("\\n========== Item Quality Among Correct Guessers (All Respondents) ==========\\n")\
results_correct <- data.frame()\
\
for (construct in names(construct_map)) \{\
  items   <- construct_map[[construct]]$items\
  correct <- construct_map[[construct]]$correct\
  \
  cat("\\n---", construct, "---\\n")\
  for (i in items) \{\
    filter_var  <- paste0("Q", i, ".2")\
    quality_var <- paste0("Q", i, ".3")\
    \
    if (filter_var %in% names(dat) & quality_var %in% names(dat)) \{\
      # N who answered the classification question (non-missing on .2)\
      n_responded <- sum(!is.na(dat[[filter_var]]))\
      # N who guessed correctly\
      n_correct <- sum(dat[[filter_var]] == correct, na.rm = TRUE)\
      pct_correct <- round(n_correct / n_responded * 100, 1)\
      \
      filtered <- dat[dat[[filter_var]] == correct & !is.na(dat[[filter_var]]), ]\
      if (nrow(filtered) > 0) \{\
        res <- desc_stats(filtered, quality_var)\
        res$Construct <- construct\
        res$N_correct <- n_correct\
        res$Pct_correct <- pct_correct\
        results_correct <- rbind(results_correct, res)\
        cat(paste0(quality_var,\
                   ": Correct guessers = ", n_correct, "/", n_responded,\
                   " (", pct_correct, "%)",\
                   " | Quality M=", res$Mean, ", SD=", res$SD,\
                   " (N with rating=", res$N, ")\\n"))\
