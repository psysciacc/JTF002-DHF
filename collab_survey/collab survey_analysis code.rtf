# Expertise variable mapping\
expertise_var_map <- list(\
  "Dignity-Self"  = "Q2.3_3",\
  "Dignity-Other" = "Q2.3_3",\
  "Honor-Self"    = "Q2.3_1",\
  "Honor-Other"   = "Q2.3_1",\
  "Face-Self"     = "Q2.3_2",\
  "Face-Other"    = "Q2.3_2"\
)\
\
build_summary_table <- function(dat, construct_name, items, correct_val, expertise_var) \{\
  \
  rows <- list()\
  \
  for (i in items) \{\
    class_var   <- paste0("Q", i, ".2")\
    quality_var <- paste0("Q", i, ".3")\
    trans_var   <- paste0("Q", i, ".4")\
    \
    if (!all(c(class_var, quality_var) %in% names(dat))) next\
    \
    # --- All respondents: % guessed correctly ---\
    n_responded_all <- sum(!is.na(dat[[class_var]]))\
    n_correct_all   <- sum(dat[[class_var]] == correct_val, na.rm = TRUE)\
    pct_correct_all <- round(n_correct_all / n_responded_all * 100, 1)\
    \
    # --- Experts: % guessed correctly ---\
    dat_expert <- dat[!is.na(dat[[expertise_var]]) & dat[[expertise_var]] > 3, ]\
    n_expert_responded <- sum(!is.na(dat_expert[[class_var]]))\
    n_expert_correct   <- sum(dat_expert[[class_var]] == correct_val, na.rm = TRUE)\
    pct_expert_correct <- ifelse(n_expert_responded > 0,\
                                 round(n_expert_correct / n_expert_responded * 100, 1),\
                                 NA)\
    \
    # --- Quality assessment (among ALL correct guessers) ---\
    dat_correct_all <- dat[dat[[class_var]] == correct_val & !is.na(dat[[class_var]]), ]\
    quality_vals <- dat_correct_all[[quality_var]]\
    quality_vals <- quality_vals[!is.na(quality_vals)]\
    quality_N  <- length(quality_vals)\
    quality_M  <- ifelse(quality_N > 0, round(mean(quality_vals), 2), NA)\
    quality_SD <- ifelse(quality_N > 1, round(sd(quality_vals), 2), NA)\
    \
    # --- Translation difficulty (all sample) ---\
    if (trans_var %in% names(dat)) \{\
      trans_vals <- dat[[trans_var]]\
      trans_vals <- trans_vals[!is.na(trans_vals)]\
      trans_N  <- length(trans_vals)\
      trans_M  <- ifelse(trans_N > 0, round(mean(trans_vals), 2), NA)\
      trans_SD <- ifelse(trans_N > 1, round(sd(trans_vals), 2), NA)\
    \} else \{\
      trans_N <- trans_M <- trans_SD <- NA\
    \}\
    \
    rows[[length(rows) + 1]] <- data.frame(\
      Item = paste0("Q", i),\
      Pct_Correct_All = pct_correct_all,\
      N_Correct_All = n_correct_all,\
      N_Responded_All = n_responded_all,\
      Pct_Correct_Expert = pct_expert_correct,\
      N_Correct_Expert = n_expert_correct,\
      N_Expert_Responded = n_expert_responded,\
      Quality_M = quality_M,\
      Quality_SD = quality_SD,\
      Quality_N = quality_N,\
      Translation_M = trans_M,\
      Translation_SD = trans_SD,\
      Translation_N = trans_N\
    )\
  \}\
  \
  tbl <- do.call(rbind, rows)\
  return(tbl)\
\}\
\
# Print formatted summary table\
print_summary_table <- function(tbl, construct_name) \{\
  cat("\\n==========", construct_name, "==========\\n\\n")\
  \
  # Create a display version\
  display <- data.frame(\
    Item = tbl$Item,\
    `Correct_All_%_(N)` = paste0(tbl$Pct_Correct_All, "% (", tbl$N_Correct_All, "/", tbl$N_Responded_All, ")"),\
    `Correct_Expert_%_(N)` = paste0(tbl$Pct_Correct_Expert, "% (", tbl$N_Correct_Expert, "/", tbl$N_Expert_Responded, ")"),\
    `Quality_M(SD)` = paste0(tbl$Quality_M, " (", tbl$Quality_SD, ")"),\
    Quality_N = tbl$Quality_N,\
    `Translation_M(SD)` = paste0(tbl$Translation_M, " (", tbl$Translation_SD, ")"),\
    Translation_N = tbl$Translation_N,\
    check.names = FALSE\
  )\
  \
  print(display, row.names = FALSE, right = FALSE)\
\}\
\
# Build and print all summary tables\
summary_tables <- list()\
\
for (construct in names(construct_map)) \{\
  items       <- construct_map[[construct]]$items\
  correct_val <- construct_map[[construct]]$correct\
  exp_var     <- expertise_var_map[[construct]]\
  \
  tbl <- build_summary_table(dat, construct, items, correct_val, exp_var)\
  summary_tables[[construct]] <- tbl\
  print_summary_table(tbl, construct)\
\}\
\
# Also save combined summary as a single data frame for export\
all_summary <- do.call(rbind, lapply(names(summary_tables), function(nm) \{\
  tbl <- summary_tables[[nm]]\
  tbl$Construct <- nm\
  tbl\
\}))\
rownames(all_summary) <- NULL\
\
cat("\\n========== Combined Summary Table ==========\\n")\
print(all_summary)\
\
cat("\\n========== Analysis Complete ==========\\n")}